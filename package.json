{
  "name": "miniapp-builder-unibest-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:uni-config": "node ./scripts/sync-uni-config.mjs",
    "tokens:build": "style-dictionary build --config style-dictionary.config.mjs",
    "tokens:watch": "style-dictionary build --watch --config style-dictionary.config.mjs",
    "icons:build": "node ./scripts/build-icons.mjs",
    "uno:build": "node ./scripts/build-uno.mjs",
    "format:generated": "node ./scripts/format-generated.mjs",
    "design:build": "npm run tokens:build && npm run icons:build && npm run uno:build && npm run format:generated",
    "sync:project-assets": "npm run design:build && npm run sync:uni-config",
    "dev:h5": "npm run sync:project-assets && uni",
    "dev:mp-weixin": "npm run sync:project-assets && uni -p mp-weixin",
    "build:h5": "npm run sync:project-assets && node ./scripts/build-uni.mjs h5",
    "build:mp-weixin": "npm run sync:project-assets && node ./scripts/build-uni.mjs mp-weixin",
    "typecheck": "npm run design:build && vue-tsc --noEmit",
    "prepublish:check": "node ./scripts/prepublish-check.mjs",
    "starter:gate": "node ./scripts/starter-gate.mjs",
    "starter:ci-gate": "npm run starter:gate --"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4070620250821001",
    "@dcloudio/uni-components": "3.0.0-4070620250821001",
    "@dcloudio/uni-h5": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4070620250821001",
    "pinia": "2.0.36",
    "vue": "^3.4.21",
    "vue-router": "4.5.1",
    "wot-design-uni": "^1.6.0"
  },
  "devDependencies": {
    "@dcloudio/vite-plugin-uni": "3.0.0-4070620250821001",
    "@iconify-json/lucide": "^1.2.67",
    "@iconify/utils": "^3.0.2",
    "@radix-ui/colors": "^3.0.0",
    "@tokens-studio/sd-transforms": "^1.2.6",
    "@dcloudio/types": "^3.4.8",
    "@types/node": "^20.17.9",
    "@uni-helper/unocss-preset-uni": "0.2.11",
    "@uni-helper/vite-plugin-uni-components": "0.2.3",
    "@uni-helper/vite-plugin-uni-manifest": "0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "0.3.23",
    "jiti": "^2.4.2",
    "open-props": "^1.7.16",
    "sass": "1.77.8",
    "style-dictionary": "^4.3.3",
    "typescript": "~5.8.0",
    "unocss": "66.0.0",
    "unplugin-auto-import": "^20.0.0",
    "vite": "5.2.8",
    "vue-tsc": "^3.0.6"
  }
}
